# Copy to .env and adjust as needed
JWT_SECRET=change-me-in-production

# Ollama models (must be pulled into the ollama container after first boot)
EMBED_MODEL=nomic-embed-text
LLM_MODEL=gemma2:2b
# Must fit the largest generation prompt (rules + two source chunks ~= 2400
# tokens). 2048 silently truncates non-MCQ prompts and makes those rows fail.
LLM_NUM_CTX=4096
# Embedding dimension must match EMBED_MODEL (nomic-embed-text = 768)
EMBED_DIM=768
RAG_TOP_K=2
RAG_QUERY_CACHE_SIZE=100
# Concurrent LLM generations. Keep <= ollama's OLLAMA_NUM_PARALLEL (4) so
# requests batch on the GPU. Higher = faster but more VRAM per in-flight request.
GEN_CONCURRENCY=4
