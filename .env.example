# Copy to .env and adjust as needed
JWT_SECRET=change-me-in-production

# Ollama models (must be pulled into the ollama container after first boot)
EMBED_MODEL=nomic-embed-text
LLM_MODEL=gemma3:1b
# Embedding dimension must match EMBED_MODEL (nomic-embed-text = 768)
EMBED_DIM=768
RAG_TOP_K=2
RAG_QUERY_CACHE_SIZE=100
